{
  "name": "seqtrack-composer",
  "version": "0.1.0",
  "private": true,
  "description": "AI-powered MIDI composition app for Yamaha SEQTRAK",
  "author": "TakTik <hello@taktik.net>",
  "main": "electron/main.js",
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "lint": "eslint",
    "electron:dev": "concurrently -k \"npm run dev\" \"wait-on http://127.0.0.1:3000 && electron .\"",
    "electron:build": "next build && electron-builder --mac --arm64",
    "electron:build:universal": "next build && electron-builder --mac --universal",
    "postinstall": "electron-builder install-app-deps"
  },
  "dependencies": {
    "@ai-sdk/anthropic": "^3.0.63",
    "@ai-sdk/google": "^3.0.53",
    "@ai-sdk/openai-compatible": "^2.0.37",
    "@ai-sdk/react": "^3.0.136",
    "@base-ui/react": "^1.3.0",
    "@mediapipe/tasks-vision": "^0.10.34",
    "@openrouter/ai-sdk-provider": "^2.3.3",
    "@tonejs/midi": "^2.0.28",
    "ai": "^6.0.134",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "lucide-react": "^0.577.0",
    "midi-writer-js": "^3.2.1",
    "next": "16.2.1",
    "react": "19.2.4",
    "react-dom": "19.2.4",
    "tailwind-merge": "^3.5.0",
    "tw-animate-css": "^1.4.0",
    "webmidi": "^3.1.14",
    "zod": "^4.3.6",
    "zustand": "^5.0.12"
  },
  "devDependencies": {
    "@tailwindcss/postcss": "^4",
    "@types/node": "^20",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "concurrently": "^9.0.0",
    "electron": "^35.0.0",
    "electron-builder": "^25.0.0",
    "eslint": "^9",
    "eslint-config-next": "16.2.1",
    "shadcn": "^4.1.0",
    "tailwindcss": "^4",
    "typescript": "^5",
    "wait-on": "^8.0.0"
  }
}
